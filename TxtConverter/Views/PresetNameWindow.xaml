<Window x:Class="TxtConverter.Views.PresetNameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Width="380" Height="200"
        WindowStartupLocation="CenterOwner"
        Title="{DynamicResource ui_preset_name_title}" Background="{StaticResource Brush_WindowBg}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="#333333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>
            <!-- Header -->
            <Grid Grid.Row="0" Background="{StaticResource Brush_WindowBg}" MouseDown="TitleBar_MouseDown" Height="40">
                <TextBlock Text="{DynamicResource ui_preset_name_title}" FontWeight="Bold" Foreground="#007ACC" Margin="15,0" VerticalAlignment="Center"/>
                <Button Style="{StaticResource CloseButton}" HorizontalAlignment="Right" Click="Cancel_Click" Content="X" WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>
            <!-- Content -->
            <Grid Grid.Row="1" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{DynamicResource ui_preset_name_label}" Foreground="#CCCCCC" Margin="0,0,0,8" FontWeight="SemiBold"/>
                <TextBox x:Name="NameInputBox" Grid.Row="1" VerticalAlignment="Top" Padding="8,6" Background="#151515" Foreground="White" BorderBrush="#333333"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="{DynamicResource ui_preset_cancel}" Click="Cancel_Click" Width="80" Margin="0,0,8,0" Background="Transparent" BorderBrush="#444"/>
                    <Button Content="{DynamicResource ui_preset_confirm}" Style="{StaticResource AccentButton}" Click="Confirm_Click" Width="100" Height="32"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>